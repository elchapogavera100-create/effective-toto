# Web Copy Cat Configuration

# Base URL to clone
TARGET_URL=https://example.com

# Output directory for cloned content
OUTPUT_DIR=./cloned-site

# Maximum depth for crawling (0 = current page only)
MAX_DEPTH=2

# Maximum number of pages to clone
MAX_PAGES=50

# Timeout for HTTP requests (milliseconds)
TIMEOUT=10000

# User Agent for requests
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# Enable verbose logging
VERBOSE=true

# Respect robots.txt
RESPECT_ROBOTS=true

# Delay between requests (milliseconds)
REQUEST_DELAY=1000
